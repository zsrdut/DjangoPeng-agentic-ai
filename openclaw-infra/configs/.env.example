# ============================================================
# OpenClaw 环境变量配置文件
# 
# 使用说明：
# 1. 复制本文件为 .env（去掉 .example 后缀）
# 2. 替换下方的占位值为你的真实 Key
# 3. 确保 .env 已加入 .gitignore（绝不要提交到 Git）
# ============================================================

# ----------------------------------------------------------
# 大模型 API 配置（OpenAI 兼容格式，选择其一）
# OpenClaw 支持任何兼容 OpenAI 接口的模型服务
# ----------------------------------------------------------

# 方式一：OpenAI 官方
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 方式二：豆包（火山引擎，推荐搭配火山引擎服务器）
# OPENAI_API_KEY=your-doubao-api-key
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 方式三：DeepSeek（性价比最高）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 方式四：通义千问（阿里云百炼）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 方式五：Kimi（Moonshot AI）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# 方式六：硅基流动（SiliconFlow，聚合多模型）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# ----------------------------------------------------------
# 请取消上方某一组的注释，填入你的真实 Key
# 以下是默认启用的示例（DeepSeek，国内性价比最高）
# ----------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
