# CRM Assistant 环境变量模板
# 复制本文件为 .env.local，填入真实值后使用：
#   set -a && source .env.local && set +a

# ── 飞书应用凭证 ──
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret

# ── Bitable 表配置 ──
# 从 Bitable URL 中提取：
#   https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>&view=...
# 注意：不要把 &view=... 一起复制进来
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_CUSTOMER_TABLE_ID=tbl_your_customer_table_id
FEISHU_OPPORTUNITY_TABLE_ID=tbl_your_opportunity_table_id
