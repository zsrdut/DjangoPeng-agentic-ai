# Morning Newspaper Assistant 环境变量模板
# 复制本文件为 .env，填入真实值后使用：
#   cp .env.example .env

# ── 邮箱提醒（可选，不配置则自动跳过邮件源） ──
# 支持任何 IMAP 邮箱（163、QQ、Gmail、Outlook 等），课程以 163 为例
# IMAP_PASS 填客户端授权码 / 应用专用密码，不是网页登录密码
# 邮箱服务器地址在 config/sources.yaml 的 assistant_mailbox 段配置
IMAP_USER=your_email@example.com
IMAP_PASS=your_imap_authorization_code

# ── GitHub API（可选，不配置则受匿名速率限制，每分钟 10 次） ──
# 获取：GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 权限：Public Repositories (read-only) 即可
GITHUB_TOKEN=github_pat_your_token_here

# ── Tavily 搜索（推荐，用于动态搜索回填采集范式） ──
# 在 https://tavily.com 注册后获取 API Key
TAVILY_API_KEY=tvly-your_tavily_api_key
